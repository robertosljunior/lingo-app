  "senses": [
    {
      "sense_id": "sense:still.continuity",
      "lexeme_id": "lexeme:still",
      "label": "Continuidade / persistência",
      "meaning_pt": "Algo continua verdadeiro ou continua acontecendo — uma ação que segue em curso ou um estado que segue valendo.",
      "gloss_en": "a state or action continues to hold",
      "communicative_function_ids": ["function:express_continuation", "function:express_persistent_state"],
      "first_exposure_stage": "A1",
      "related_sense_ids": [],
      "notes": "Núcleo semântico único realizado por construções diferentes: 'I still live here.' (verbo lexical) e 'I am still tired.' (be + complemento) compartilham este sentido."
    },
    {
      "sense_id": "sense:still.counter_expectation",
      "lexeme_id": "lexeme:still",
      "label": "Persistência apesar de obstáculo",
      "meaning_pt": "A ação ou o resultado acontece mesmo havendo um obstáculo ou uma razão para esperar o contrário.",
      "gloss_en": "the outcome holds despite an obstacle or contrary expectation",
      "communicative_function_ids": ["function:express_result_despite_obstacle"],
      "first_exposure_stage": "A2",
      "related_sense_ids": ["sense:still.continuity"],
      "notes": "Decisão de modelagem: sentido próprio, documentado como extensão concessiva convencionalizada da continuidade (related_sense_ids). A leitura concessiva completa emerge da COMBINAÇÃO deste sentido com as construções but/although e com as funções comunicativas — ver docs/pedagogy-v2-content-model.md."
    },
    {
      "sense_id": "sense:still.discourse_reservation",
      "lexeme_id": "lexeme:still",
      "label": "Marcador discursivo de ressalva",
      "meaning_pt": "Organiza o discurso: reconhece o que foi dito antes e introduz uma ressalva ou contraste.",
      "gloss_en": "clause-initial discourse marker introducing a reservation",
      "communicative_function_ids": ["function:introduce_discourse_reservation"],
      "first_exposure_stage": "B1",
      "related_sense_ids": ["sense:still.counter_expectation"],
      "notes": "Distingue-se do advérbio intraoracional pela posição inicial de oração seguida de vírgula (representada na construção), e por operar sobre o discurso anterior, não sobre o predicado."
    }
  ],
